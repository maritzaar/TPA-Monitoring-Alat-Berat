APP_NAME="Monitoring Alat Berat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.railway.app

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=error

# === DATABASE ===
# Railway akan mengisi otomatis jika kamu tambah plugin MySQL:
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# === SESSION & CACHE ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# === FILESYSTEM ===
FILESYSTEM_DISK=local

# === MAIL (opsional) ===
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@monitoring-alat-berat.com"
MAIL_FROM_NAME="${APP_NAME}"

# === VITE ===
VITE_APP_NAME="${APP_NAME}"
