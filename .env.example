APP_NAME="Monitoring Alat Berat"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=error

# === DATABASE (PostgreSQL - diisi dari Render dashboard) ===
DB_CONNECTION=pgsql
DB_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

# === SESSION & CACHE ===
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# === FILESYSTEM ===
FILESYSTEM_DISK=local

# === MAIL ===
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@monitoring-alat-berat.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
